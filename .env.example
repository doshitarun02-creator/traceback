# TraceBack Environment Configuration
SECRET_KEY=traceback_secret_change_this_in_production

# AI Triage (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Evidence Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Service (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_USE_TLS=true

MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/traceback?retryWrites=true&w=majority
DB_NAME=traceback
